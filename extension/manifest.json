{
  "manifest_version": 3,

  "name": "Phishing Detector",
  "version": "1.0",

  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "notifications"
  ],

  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  }
}
